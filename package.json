{
  "name": "git-ai",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "cli:commit": "pnpm --filter @git-ai/cli commit",
    "cli:diff": "pnpm --filter @git-ai/cli diff",
    "cli:issue": "pnpm --filter @git-ai/cli... build && node packages/cli/dist/index.js issue",
    "cli:test-backlog": "pnpm --filter @git-ai/cli... build && node packages/cli/dist/index.js test-backlog",
    "dev": "pnpm -r dev",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.7.0",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
