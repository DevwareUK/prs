# Dependencies
node_modules/

# Package manager local state
.pnpm-store/
.npm/
.pnpm-workspace-state*
pnpm-workspace.yaml.tmp

# Build outputs (internal workspace packages should never commit dist)
/packages/*/dist/

# Action dist policy: keep runtime JS committable, ignore type/meta outputs
/actions/*/dist/*.d.ts
/actions/*/dist/*.d.ts.map
/actions/*/dist/*.js.map

# Caches and test/build coverage artifacts
build/
coverage/
*.tsbuildinfo
.turbo/
.cache/
.prs/
.git-ai/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# Husky generated local shims
.husky/_/

# Editor / IDE
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db
