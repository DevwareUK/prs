{
  "name": "@git-ai/cli",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "git-ai": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "commit": "pnpm --filter @git-ai/cli... build && node dist/index.js commit",
    "diff": "pnpm --filter @git-ai/cli... build && node dist/index.js diff"
  },
  "dependencies": {
    "@git-ai/core": "workspace:*",
    "@git-ai/providers": "workspace:*",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
