{
  "name": "@prs/cli",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prs": "dist/index.js",
    "git-ai": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "commit": "pnpm --filter @prs/cli... build && node dist/index.js commit",
    "diff": "pnpm --filter @prs/cli... build && node dist/index.js diff",
    "feature-backlog": "pnpm --filter @prs/cli... build && node dist/index.js feature-backlog",
    "issue": "pnpm --filter @prs/cli... build && node dist/index.js",
    "review": "pnpm --filter @prs/cli... build && node dist/index.js review"
  },
  "dependencies": {
    "@prs/contracts": "workspace:*",
    "@prs/core": "workspace:*",
    "@prs/providers": "workspace:*",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
