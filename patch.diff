diff --git a/.husky/prepare-commit-msg b/.husky/prepare-commit-msg
new file mode 100755
index 0000000..5eef6b0
--- /dev/null
+++ b/.husky/prepare-commit-msg
@@ -0,0 +1,65 @@
+msg_file=$1
+source=$2
+
+set +e
+
+# Skip flows where Git or the user already supplied the message.
+case "$source" in
+  message|merge|squash|commit)
+    exit 0
+    ;;
+esac
+
+if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
+  exit 0
+fi
+
+comment_char=$(git config --get core.commentChar 2>/dev/null)
+case "$comment_char" in
+  ""|auto)
+    comment_char="#"
+    ;;
+esac
+
+# Skip if the message file already has real content beyond blank lines/comments.
+if awk -v comment_char="$comment_char" '
+  {
+    line = $0
+    sub(/^[[:space:]]*/, "", line)
+    if (line == "") {
+      next
+    }
+    if (substr(line, 1, length(comment_char)) == comment_char) {
+      next
+    }
+    found = 1
+    exit
+  }
+  END { exit found ? 0 : 1 }
+' "$msg_file"
+then
+  exit 0
+fi
+
+repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
+if [ -z "$repo_root" ]; then
+  printf '%s\n' "husky: could not determine repo root; skipping AI commit message generation." >&2
+  exit 0
+fi
+
+generated_message=$(
+  cd "$repo_root" &&
+    pnpm --silent --filter @ai-actions/cli commit 2>/dev/null
+)
+status=$?
+
+if [ $status -ne 0 ] || [ -z "$generated_message" ]; then
+  printf '%s\n' "husky: could not pre-populate the commit message; continuing without AI output." >&2
+  exit 0
+fi
+
+if ! printf '%s\n' "$generated_message" >"$msg_file"; then
+  printf '%s\n' "husky: could not write the generated commit message; continuing without AI output." >&2
+fi
+
+exit 0
diff --git a/ARCHITECTURE.md b/ARCHITECTURE.md
index 9942053..639d146 100644
--- a/ARCHITECTURE.md
+++ b/ARCHITECTURE.md
@@ -25,3 +25,11 @@ This repository is a pnpm monorepo for reusable AI-powered GitHub Actions.
 - Prefer small vertical slices over broad incomplete abstractions.
 - Build one provider first: OpenAI.
 - Build one action first: `pr-description`.
+
+## Local hooks
+
+Husky is configured through the root `prepare` script. Run `pnpm install` once in the repo to enable local Git hooks.
+
+The local `prepare-commit-msg` hook pre-populates the commit message before the editor opens by calling the existing CLI commit generator. It uses the same environment variables as the CLI: `OPENAI_API_KEY`, optional `OPENAI_MODEL`, and optional `OPENAI_BASE_URL`.
+
+The hook is non-blocking. If AI generation fails, the commit still proceeds. It skips flows where Git or the user already supplied the message, including merge, squash, amend/reuse, and manual `-m` or `-F` commit messages.
